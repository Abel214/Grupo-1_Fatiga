import threading
import time

import cv2
from flask import Flask, render_template, Response

from detector import FatigueDetector

app = Flask(__name__)

detector = FatigueDetector()


class CameraStream:
    def __init__(self, index):
        self.cap = cv2.VideoCapture(index, cv2.CAP_DSHOW)

        # Buffer mínimo: siempre el frame más reciente, no uno viejo.
        self.cap.set(cv2.CAP_PROP_BUFFERSIZE, 1)
        self.cap.set(cv2.CAP_PROP_FRAME_WIDTH, 640)
        self.cap.set(cv2.CAP_PROP_FRAME_HEIGHT, 480)

        self.frame = None
        self.lock = threading.Lock()
        self.running = self.cap.isOpened()

        if self.running:
            self.thread = threading.Thread(target=self._update, daemon=True)
            self.thread.start()

    def isOpened(self):
        return self.cap.isOpened()

    def _update(self):
        while self.running:
            success, frame = self.cap.read()
            if success:
                with self.lock:
                    self.frame = frame
            else:
                time.sleep(0.01)

    def read(self):
        with self.lock:
            if self.frame is None:
                return False, None
            return True, self.frame.copy()

    def release(self):
        self.running = False
        if hasattr(self, "thread"):
            self.thread.join(timeout=1)
        self.cap.release()


camera = None


def generate_frames():

    global camera

    if camera is None:
        return

    while True:

        success, frame = camera.read()

        if not success or frame is None:
            # Todavía no hay frame disponible del hilo de captura
            time.sleep(0.01)
            continue

        frame = detector.process_frame(frame)

        ret, buffer = cv2.imencode(".jpg", frame)

        if not ret:
            continue

        frame_bytes = buffer.tobytes()

        yield (
            b'--frame\r\n'
            b'Content-Type: image/jpeg\r\n\r\n' +
            frame_bytes +
            b'\r\n'
        )


@app.route("/")
def index():
    return render_template("index.html")


@app.route("/video")
def video():

    return Response(
        generate_frames(),
        mimetype="multipart/x-mixed-replace; boundary=frame"
    )


@app.route("/start/<int:index>")
def start(index):

    global camera

    if camera is not None:
        camera.release()

    camera = CameraStream(index)

    if not camera.isOpened():
        return "No se pudo abrir la cámara", 500

    return "OK"


@app.route("/estado")
def estado():

    return detector.get_metrics()


@app.route("/camaras")
def camaras():

    disponibles = []

    for i in range(10):

        cap = cv2.VideoCapture(i, cv2.CAP_DSHOW)

        if cap.isOpened():

            ret, _ = cap.read()

            if ret:
                disponibles.append(i)

        cap.release()

    return {
        "camaras": disponibles
    }


if __name__ == "__main__":
    app.run(debug=False, threaded=True)